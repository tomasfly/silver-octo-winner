{
  "name": "tribbu-onboarding-qa",
  "version": "1.0.0",
  "private": true,
  "description": "Automatizacion QA onboarding (Appium + TypeScript)",
  "scripts": {
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test:smoke": "mocha -r ts-node/register src/tests/**/*.spec.ts --timeout 240000",
    "test:dni": "ts-node src/scripts/testDniProvider.ts",
    "test:report": "ts-node src/scripts/runWithReports.ts",
    "test": "npm run test:smoke",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "mocha": "^10.8.2",
    "playwright-core": "^1.52.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "webdriverio": "^8.43.0"
  }
}
